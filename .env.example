# Скопируйте в .env и поправьте под окружение перед `docker compose up`

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-in-production
# Шифрует секреты интеграций и уведомлений (пароль SMTP, токены ботов, вебхуки) в БД.
# Сгенерировать: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
# Меняйте все три под реальный сервер/домен, если не localhost - иначе вход и любой другой
# запрос к API будут падать с "Bad Request (400)", хотя сам фронтенд откроется нормально.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8090
CSRF_TRUSTED_ORIGINS=http://localhost:8090

POSTGRES_DB=awareness
POSTGRES_USER=awareness
POSTGRES_PASSWORD=change-me

HTTP_PORT=8090

# LDAP/Active Directory больше не настраивается через .env - см. консоль администратора,
# раздел "LDAP/AD" (/console/ldap). Конфигурация хранится в БД и применяется без рестарта.
